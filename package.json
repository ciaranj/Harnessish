{
  "name": "harnessish",
  "version": "1.0.0",
  "description": "A ropey AI harness to get my head around some of the tool calling in 'proper' approaches",
  "main": "build/index.js",
  "bin": {
    "harnessish": "build/index.js"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "rm -rf build && tsc && (echo '#!/usr/bin/env node' && cat build/index.js) > build/_tmp.js && mv build/_tmp.js build/index.js && chmod +x build/index.js",
    "start": "node build/index.js",
    "dev": "tsx ./src/index.tsx"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ciaranj/Harnessish.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ciaranj/Harnessish/issues"
  },
  "homepage": "https://github.com/ciaranj/Harnessish#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "ink": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^3.0.0"
  }
}